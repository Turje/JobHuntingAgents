# LLM Provider: "gemini" (free) or "anthropic"
LLM_PROVIDER=gemini

# Google Gemini (free — 1,500 requests/day)
GEMINI_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-2.0-flash

# Anthropic (optional — requires API credits)
# ANTHROPIC_API_KEY=your_key_here
# CLAUDE_MODEL=claude-sonnet-4-6

# Serper.dev (primary — full Google web search, free 2,500/month)
# SERPER_API_KEY=your_serper_key_here

# Google Custom Search (fallback when Serper credits run out)
# GOOGLE_API_KEY=your_google_api_key
# GOOGLE_CSE_ID=your_cse_id

# Gmail API (Optional — for draft creation)
# GMAIL_CREDENTIALS_PATH=credentials.json
# GMAIL_TOKEN_PATH=token.json

# Rate Limits
# MAX_RETRIES=3
# RETRY_BASE_DELAY=1.0
# MAX_COMPANIES_PER_SEARCH=15
# MAX_OUTREACH_PER_DAY=10

# Server
# HOST=127.0.0.1
# PORT=8000

# DSPy (Optional — for auto-optimizable prompt modules)
# DSPY_ENABLED=false
# DSPY_OPTIMIZED_PATH=data/optimized
